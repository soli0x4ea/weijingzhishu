{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dlc://schemas/behavior.schema.json",
  "title": "Behavior Module",
  "description": "Behavior rules module (LWS). Required for L2+ (depends on engine).",
  "type": "object",
  "required": [
    "enabled"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Enable behavior module (L2+)."
    },
    "lws_rules": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^behavior/lws_rules\\.json$",
      "description": "Path to LWS rules config."
    }
  }
}